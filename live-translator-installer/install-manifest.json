            "precacher-ui.json",
            "precacher-ui/app.js",
            "precacher-ui/index.html",
            "precacher-ui/style.css"
        ]
    },
    "runtime": {
        "minNwVersion": "0.105.0",
        "loaderHelpers": [
            "loader/path-resolver.js",
            "loader/script-injector.js"
        ],
        "requiredAssets": [
            "translator.json",
            "settings.json"
        ],
        "optionalAssets": [
