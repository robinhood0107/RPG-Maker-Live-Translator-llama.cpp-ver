            "hooks/bitmap/invalidation.js",
            "hooks/bitmap/replay.js",
            "hooks/bitmap/state.js",
            "hooks/bitmap/translation.js",
            "hooks/bitmap-draw-text-hook.js",
            "hooks/choice-list-hook.js",
            "hooks/game-message-hook.js",
            "hooks/help-window-hook.js",
            "hooks/pixi-text-hook.js",
            "hooks/sprite-text-hook.js",
            "hooks/window-draw-hooks.js",
            "hooks/window-helpers.js",
            "hooks/window-state-hooks.js",
            "install-manifest.json",
            "loader/path-resolver.js",
            "loader/script-injector.js",
            "logger.js",
            "precacher/app.js",
            "precacher/index.html",
            "precacher/precacher.js",
            "precacher/pretranslator.js",
            "precacher/style.css",
            "precacher/ui.json",
            "runtime/cache-context.js",
            "runtime/hook-context.js",
            "runtime/install-hooks.js",
            "runtime/logger-context.js",
            "runtime/paths.js",
            "runtime/performance-profiler.js",
            "runtime/provider.js",
            "runtime/text-tracker.js",
            "translator.js",
            "translation-manager.js",
            "translator.json",
            "ui-launcher.js"
        ],
        "obsolete": [
            "hooks.js",
            "hooks/text-hooks.js",
            "hooks/performance-profiler.js",
            "hooks/bitmap/sprite-candidates.js",
            "hooks/bitmap/sprite-glyphs.js",
