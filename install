#!/bin/bash

# Cross-platform installer for Text Replacement Addon
# Detects OS and runs appropriate installer script

detect_os() {
    case "$(uname -s)" in
        CYGWIN*|MINGW32*|MSYS*|MINGW*)
            echo "windows"
            ;;
        Darwin)
            echo "macos"
            ;;
        Linux)
            echo "linux"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

OS=$(detect_os)

case $OS in
    "windows")
        echo "Detected Windows - running PowerShell installer..."
        if command -v powershell >/dev/null 2>&1; then
            powershell -ExecutionPolicy Bypass -File "./installer.ps1"
        elif command -v pwsh >/dev/null 2>&1; then
            pwsh -ExecutionPolicy Bypass -File "./installer.ps1"
        else
            echo "Error: PowerShell not found. Please install PowerShell or run installer.bat instead."
            exit 1
        fi
        ;;
    "macos"|"linux")
        echo "Detected $OS - running bash installer..."
        if [ -f "./installer.sh" ]; then
            chmod +x "./installer.sh"
            ./installer.sh
        else
            echo "Error: installer.sh not found"
            exit 1
        fi
        ;;
    "unknown")
        echo "Unknown operating system. Please run the appropriate installer manually:"
        echo "  Windows: installer.bat or installer.ps1"
        echo "  macOS/Linux: installer.sh"
        exit 1
        ;;
esac