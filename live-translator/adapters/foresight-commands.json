  "stopReasons": {
    "barrier-command": "Stopped at a command that can change control flow or exit the current path.",
    "branch-depth-limit": "Stopped after reaching the branch nesting limit.",
    "branch-structure-desync": "Stopped because a branch command list did not match the expected structural markers.",
    "current-message-unattached": "Current message has no verified interpreter origin.",
    "empty-message": "Stopped at an empty Show Text block.",
    "budget-limit": "Stopped after spending the foresight budget.",
    "common-event-cycle": "Stopped before recursively scanning a common event already on the call stack.",
    "common-event-depth-limit": "Stopped after reaching the common event nesting limit.",
    "common-event-missing-id": "Stopped at a Common Event command without a valid common event id.",
    "common-event-missing-list": "Stopped at a Common Event command whose target list was unavailable.",
    "event-end": "Reached the end of the event list or branch list.",
    "indent-boundary": "Stopped before crossing an event indent boundary.",
    "message-limit": "Stopped after reaching the foresight message limit.",
    "missing-command": "Stopped at a missing or invalid command entry.",
    "movement-route-missing-list": "Stopped at a movement route without readable route commands.",
    "nested-list-cycle": "Stopped before recursively scanning an embedded command list already on the call stack.",
    "nested-list-depth-limit": "Stopped after reaching the embedded command list nesting limit.",
    "nested-list-limit": "Stopped at a command with too many embedded command lists.",
    "orphan-continuation": "Stopped at a continuation command without its owning command.",
    "path-cycle": "Stopped before revisiting a command path already scanned in this lookahead.",
    "scan-limit": "Stopped after reaching the foresight scan command limit.",
    "show-text": "Found a Show Text block.",
    "advance": "Advanced past a linear command.",
    "movement-route": "Advanced past a movement route.",
    "movement-route-barrier": "Stopped at a movement route command that must remain a barrier.",
    "nested-list-unavailable": "Stopped at a declared nested command list that could not be read.",
    "control-flow-target": "Stopped after resolving a static loop, break, or jump target.",
    "unsafe-control-flow": "Stopped at a loop or jump that would require runtime execution to resolve.",
    "unsupported-branch": "Stopped at a branch command that does not expose a supported structural branch shape."
  }
}
